{
  "info": {
    "name": "Niyojan Backend MVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Phase-oriented collection for the current Niyojan backend implementation."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "mockUserId", "value": "10000000-0000-4000-8000-000000000002" },
    { "key": "mockOrgId", "value": "11111111-1111-4111-8111-111111111111" },
    { "key": "mockRole", "value": "ngo_admin" },
    { "key": "mockFirebaseUid", "value": "firebase-ngo-admin-a-001" },
    { "key": "templateId", "value": "60000000-0000-4000-8000-000000000001" },
    { "key": "templateVersionId", "value": "61000000-0000-4000-8000-000000000001" },
    { "key": "documentId", "value": "50000000-0000-4000-8000-000000000001" },
    { "key": "surveyId", "value": "80000000-0000-4000-8000-000000000001" },
    { "key": "needId", "value": "90000000-0000-4000-8000-000000000001" },
    { "key": "assignmentId", "value": "92000000-0000-4000-8000-000000000001" },
    { "key": "volunteerId", "value": "70000000-0000-4000-8000-000000000001" }
  ],
  "item": [
    {
      "name": "Health and Auth",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "http://localhost:8080/health" }
        },
        {
          "name": "Auth Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Core Data",
      "item": [
        {
          "name": "List Field Catalog",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/field-catalog?page=1&pageSize=10"
          }
        },
        {
          "name": "List Skills",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/skills?page=1&pageSize=10"
          }
        },
        {
          "name": "List Volunteers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/volunteers?page=1&pageSize=10"
          }
        }
      ]
    },
    {
      "name": "Documents and Forms",
      "item": [
        {
          "name": "Create Upload URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"file_name\": \"household_assessment_april.pdf\",\n  \"file_type\": \"application/pdf\"\n}" },
            "url": "{{baseUrl}}/documents/upload-url"
          }
        },
        {
          "name": "Preview Extraction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/ai/documents/{{documentId}}/preview-extraction"
          }
        },
        {
          "name": "List Form Templates",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/form-templates?page=1&pageSize=10"
          }
        }
      ]
    },
    {
      "name": "Pipeline",
      "item": [
        {
          "name": "Start Document Pipeline",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/documents/{{documentId}}/pipeline/start"
          }
        },
        {
          "name": "Get Pipeline Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/documents/{{documentId}}/pipeline/status"
          }
        },
        {
          "name": "Get Review Package",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/documents/{{documentId}}/review-package"
          }
        },
        {
          "name": "List Pipeline Queue",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/pipeline/queue"
          }
        }
      ]
    },
    {
      "name": "Surveys and Needs",
      "item": [
        {
          "name": "Get Survey",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/surveys/{{surveyId}}"
          }
        },
        {
          "name": "Analyze Survey Needs",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/surveys/{{surveyId}}/analyze-needs"
          }
        },
        {
          "name": "List Needs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/needs?page=1&pageSize=10"
          }
        },
        {
          "name": "Get Need Matches",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/needs/{{needId}}/matches"
          }
        }
      ]
    },
    {
      "name": "Assignments and Dashboard",
      "item": [
        {
          "name": "Create Assignment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"need_id\": \"{{needId}}\",\n  \"volunteer_id\": \"{{volunteerId}}\"\n}" },
            "url": "{{baseUrl}}/assignments"
          }
        },
        {
          "name": "List Assignments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/assignments?page=1&pageSize=10"
          }
        },
        {
          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/dashboard/summary"
          }
        },
        {
          "name": "Dashboard Pipeline Health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/dashboard/pipeline-health"
          }
        }
      ]
    },
    {
      "name": "Feedback and Closure",
      "item": [
        {
          "name": "Submit Assignment Feedback",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-mock-user-id", "value": "10000000-0000-4000-8000-000000000004" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "volunteer" },
              { "key": "x-mock-firebase-uid", "value": "firebase-volunteer-a-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visit_completed\": true,\n  \"visit_date\": \"2026-04-26\",\n  \"need_confirmed\": true,\n  \"actual_situation_summary\": \"Visited the location and verified the reported situation.\",\n  \"actual_urgency_assessment\": \"correct\",\n  \"actual_affected_count\": 6,\n  \"was_ai_extraction_accurate\": true,\n  \"evidence_gcs_paths\": [\"orgs/demo/evidence/photo1.jpg\"],\n  \"action_taken\": \"Completed first response and documented the case.\",\n  \"resolution_status\": \"partially_resolved\"\n}"
            },
            "url": "{{baseUrl}}/assignments/{{assignmentId}}/feedback"
          }
        },
        {
          "name": "Get Assignment Feedback",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "url": "{{baseUrl}}/assignments/{{assignmentId}}/feedback"
          }
        },
        {
          "name": "Create Feedback Evidence Upload URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-mock-user-id", "value": "10000000-0000-4000-8000-000000000004" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "volunteer" },
              { "key": "x-mock-firebase-uid", "value": "firebase-volunteer-a-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"file_name\": \"visit-photo.jpg\",\n  \"file_type\": \"image/jpeg\"\n}"
            },
            "url": "{{baseUrl}}/assignments/{{assignmentId}}/feedback/evidence-url"
          }
        },
        {
          "name": "Close Need With Outcome",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-mock-user-id", "value": "{{mockUserId}}" },
              { "key": "x-mock-org-id", "value": "{{mockOrgId}}" },
              { "key": "x-mock-role", "value": "{{mockRole}}" },
              { "key": "x-mock-firebase-uid", "value": "{{mockFirebaseUid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignment_id\": \"{{assignmentId}}\",\n  \"feedback_id\": \"<replace-after-feedback-submit>\",\n  \"outcome\": \"partially_resolved\",\n  \"extraction_was_accurate\": true,\n  \"urgency_was_accurate\": true,\n  \"category_was_accurate\": true,\n  \"matching_was_appropriate\": true,\n  \"coordinator_notes\": \"Coordinator reviewed the field feedback and closed this case.\"\n}"
            },
            "url": "{{baseUrl}}/needs/{{needId}}/close"
          }
        }
      ]
    }
  ]
}
